    fi

    if [ "$run_tests" = "1" ]; then
        if ! run_test_mode "$test_mode"; then
            echo "Warning: advisory tests failed in mode '$test_mode'. Continuing with dev server."
        fi
    fi

    if [ "$dry_run" = "1" ]; then
        if [ "$scoped_mode" = "1" ]; then
