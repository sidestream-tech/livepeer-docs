    fi
    if [ -n "$scope_tabs" ]; then
        env_vars+=("LPD_MINT_SCOPE_TABS=$scope_tabs")
    fi
    if [ -n "$scope_prefixes" ]; then
        env_vars+=("LPD_MINT_SCOPE_PREFIXES=$scope_prefixes")
    fi
    if [ "$skip_external_fetch" = "1" ]; then
        env_vars+=("MINT_SKIP_EXTERNAL_FETCH=1")
    fi
    if [ "$disable_openapi" = "1" ]; then
        env_vars+=("LPD_MINT_DISABLE_OPENAPI=1")
    fi

    if [ "${#env_vars[@]}" -gt 0 ]; then
        if [ "${#mint_args[@]}" -gt 0 ]; then
            env "${env_vars[@]}" "$script_path" "${mint_args[@]}"
        else
            env "${env_vars[@]}" "$script_path"
        fi
        return
    fi

    if [ "${#mint_args[@]}" -gt 0 ]; then
        "$script_path" "${mint_args[@]}"
    else
        "$script_path"
    fi
}

cmd_test() {
    local mode="fast"
    local run_browser=0
    local domain_scope=""
    local run_wcag=0
    local run_link_audit_external=0
    local wcag_no_fix=0
    local base_url=""

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --staged)
                mode="staged"
                ;;
            --full)
                mode="full"
                ;;
            --browser)
                run_browser=1
                ;;
            --domain)
                if [ "$#" -lt 2 ]; then
                    finish 1 "test" "--domain requires v1|v2|both."
                    return 1
                fi
                domain_scope="$2"
                shift
                ;;
            --wcag)
                run_wcag=1
                ;;
            --wcag-no-fix)
                run_wcag=1
                wcag_no_fix=1
                ;;
            --link-audit-external)
                run_link_audit_external=1
                ;;
            --base-url)
                if [ "$#" -lt 2 ]; then
                    finish 1 "test" "--base-url requires a URL."
                    return 1
                fi
                base_url="$2"
                shift
                ;;
            --json)
                GLOBAL_JSON=1
                ;;
            --help|-h)
                cat <<'EOF'
Usage: lpd test [--staged|--full] [--browser] [--domain v1|v2|both] [--wcag] [--wcag-no-fix] [--link-audit-external] [--base-url URL] [--json]
EOF
                return 0
                ;;
            *)
                finish 1 "test" "Unknown option: $1"
                return 1
                ;;
        esac
        shift
    done

    local failures=0

    if ! run_test_mode "$mode"; then
        failures=$((failures + 1))
    fi

    if [ "$run_browser" = "1" ]; then
        if ! node tests/integration/browser.test.js; then
            failures=$((failures + 1))
        fi
    fi

    if [ -n "$domain_scope" ]; then
        local -a domain_cmd
        domain_cmd=(node tests/integration/domain-pages-audit.js --version "$domain_scope")
        if [ -n "$base_url" ]; then
            domain_cmd+=(--base-url "$base_url")
        fi
        if ! "${domain_cmd[@]}"; then
            failures=$((failures + 1))
        fi
    fi

    if [ "$run_wcag" = "1" ]; then
        local -a wcag_cmd
        wcag_cmd=(node tests/integration/v2-wcag-audit.js)
        case "$mode" in
            full)
                wcag_cmd+=(--full)
                ;;
            *)
                wcag_cmd+=(--staged --max-pages 10)
                ;;
        esac
        if [ "$wcag_no_fix" = "1" ]; then
            wcag_cmd+=(--no-fix)
        fi
        if [ -n "$base_url" ]; then
            wcag_cmd+=(--base-url "$base_url")
        fi
        if ! "${wcag_cmd[@]}"; then
            failures=$((failures + 1))
        fi
    fi

    if [ "$run_link_audit_external" = "1" ]; then
        local external_report
        local external_report_json
        local -a external_link_cmd
        case "$mode" in
            full)
                external_report="/tmp/v2-link-audit-external-full.md"
                external_report_json="/tmp/v2-link-audit-external-full.json"
                external_link_cmd=(
                    node tests/integration/v2-link-audit.js
                    --full
                    --external-policy validate
                    --external-link-types navigational
                    --no-write-links
                    --report "$external_report"
                    --report-json "$external_report_json"
                )
                ;;
            *)
                external_report="/tmp/v2-link-audit-external-staged.md"
                external_report_json="/tmp/v2-link-audit-external-staged.json"
                external_link_cmd=(
                    node tests/integration/v2-link-audit.js
                    --staged
                    --external-policy validate
                    --external-link-types navigational
                    --no-write-links
                    --report "$external_report"
                    --report-json "$external_report_json"
                )
                ;;
        esac

        if ! "${external_link_cmd[@]}"; then
            if [ "$mode" = "full" ]; then
                failures=$((failures + 1))
                echo "External link audit failed in full mode (blocking). Reports: $external_report, $external_report_json"
            else
                echo "Warning: external link audit failed in '$mode' mode (advisory). Reports: $external_report, $external_report_json"
            fi
        else
            echo "External link audit completed successfully. Reports: $external_report, $external_report_json"
        fi
    fi

    if [ "$failures" -gt 0 ]; then
        finish 1 "test" "Test command completed with $failures failing step(s)."
        return 1
    fi
    finish 0 "test" "Test command completed successfully."
}

