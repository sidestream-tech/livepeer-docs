cmd_move_page() {
    local check_only=0
    local stage_changes=1
    local assume_yes=0

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --check)
                check_only=1
                ;;
            --no-stage)
                stage_changes=0
                ;;
            --yes)
                assume_yes=1
                ;;
            --json)
                GLOBAL_JSON=1
                ;;
            --help|-h)
                cat <<'EOF'
Usage: lpd move-page <old> <new> [--yes] [--check] [--no-stage] [--json]
EOF
                return 0
                ;;
            --*)
                finish 1 "move-page" "Unknown option: $1"
                return 1
                ;;
            *)
                break
                ;;
        esac
        shift
    done

    if [ "$#" -ne 2 ]; then
        finish 1 "move-page" "Usage: lpd move-page <old> <new> [--yes] [--check] [--no-stage]"
        return 1
    fi

    local source_path="$1"
    local target_path="$2"
    local -a sync_cmd
    sync_cmd=(node tools/scripts/remediators/content/sync-docs-paths.js)

    if [ "$check_only" = "1" ]; then
        sync_cmd+=(--dry-run)
    else
        if [ "$assume_yes" != "1" ]; then
            printf 'Move %s -> %s and sync docs paths? [y/N] ' "$source_path" "$target_path"
            read -r reply
            case "$reply" in
                y|Y|yes|YES) ;;
                *)
                    finish 1 "move-page" "Cancelled."
                    return 1
                    ;;
            esac
        fi

        if ! git mv -- "$source_path" "$target_path"; then
            finish 1 "move-page" "git mv failed."
            return 1
        fi

        sync_cmd+=(--write)
    fi

    sync_cmd+=(--from "$source_path" --to "$target_path")
    if [ "$stage_changes" = "1" ] && [ "$check_only" != "1" ]; then
        sync_cmd+=(--stage)
    fi

    if ! "${sync_cmd[@]}"; then
        finish 1 "move-page" "Docs path sync failed."
        return 1
    fi

    finish 0 "move-page" "Docs move sync completed successfully."
}

cmd_scripts_list() {
    local group_filter=""
    local show_ignored=0

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --group)
                if [ "$#" -lt 2 ]; then
                    finish 1 "scripts list" "--group requires a value."
                    return 1
                fi
                group_filter="$2"
                shift
                ;;
            --show-ignored)
                show_ignored=1
                ;;
            --json)
                GLOBAL_JSON=1
                ;;
            --help|-h)
                cat <<'EOF'
Usage: lpd scripts list [--group tools|tasks|tests|v2|hooks] [--show-ignored] [--json]
EOF
                return 0
                ;;
            *)
                finish 1 "scripts list" "Unknown option: $1"
                return 1
                ;;
        esac
        shift
    done

    local groups="tools tasks tests v2 hooks"
    if [ -n "$group_filter" ]; then
        groups="$group_filter"
    fi

    local count=0
    if [ "$GLOBAL_JSON" != "1" ]; then
        printf '%-8s %-8s %-55s %s\n' "GROUP" "RISK" "COMMAND" "PATH"
        printf '%-8s %-8s %-55s %s\n' "-----" "----" "-------" "----"
    fi

    for group in $groups; do
        group_root "$group" >/dev/null || {
            finish 1 "scripts list" "Unknown group: $group"
            return 1
        }
        while IFS='|' read -r kind id rel risk extra; do
            if [ "$kind" = "ignored" ] && [ "$show_ignored" != "1" ]; then
                continue
            fi
            count=$((count + 1))
            if [ "$GLOBAL_JSON" != "1" ]; then
                if [ "$kind" = "ignored" ]; then
                    printf '%-8s %-8s %-55s %s\n' "$group" "$risk" "${id#"$group "}" "IGNORED ($extra)"
                else
                    printf '%-8s %-8s %-55s %s\n' "$group" "$risk" "${id#"$group "}" "$rel"
                fi
            fi
        done < <(discover_group_scripts "$group" "$show_ignored")
    done

    finish 0 "scripts list" "Listed $count script command(s)."
}

cmd_scripts_run_internal() {
    local group="$1"
    shift
    local -a cmd_tokens
    cmd_tokens=()
    local -a script_args
    script_args=()
    LP_DRY_RUN=0
    LP_ASSUME_YES=0

    while [ "$#" -gt 0 ]; do
        case "$1" in
            --dry-run)
                LP_DRY_RUN=1
                shift
                ;;
            --yes)
                LP_ASSUME_YES=1
                shift
                ;;
            --json)
                GLOBAL_JSON=1
                shift
                ;;
            --help|-h)
                cat <<'EOF'
Usage:
  lpd scripts run <group> <script-path tokens...> [--dry-run] [--yes] [-- script args]

Example:
  lpd scripts run tools dev test-add-callouts -- --help
EOF
                return 0
                ;;
            --)
                shift
                script_args=("$@")
                break
                ;;
            *)
                cmd_tokens+=("$1")
                shift
                ;;
        esac
    done

    if [ "${#cmd_tokens[@]}" -eq 0 ]; then
        finish 1 "scripts run" "Missing script path tokens."
        return 1
    fi

    if ! group_root "$group" >/dev/null 2>&1; then
        finish 1 "scripts run" "Unknown group: $group"
        return 1
    fi

    resolve_script_entry "$group" "${cmd_tokens[@]}" || true
    if [ -z "$RESOLVED_REL" ]; then
        if [ -n "$RESOLVED_IGNORE" ]; then
            finish 1 "scripts run" "Command is ignored by .lpdignore: $RESOLVED_IGNORE"
            return 1
        fi
        finish 1 "scripts run" "Script not found: $group ${cmd_tokens[*]}"
        return 1
    fi

    if [ "$RESOLVED_RISK" = "high" ]; then
        confirm_high_risk "$RESOLVED_ID" || return 1
    fi

    if [ "${#script_args[@]}" -gt 0 ]; then
        run_script_file "$RESOLVED_REL" "${script_args[@]}"
    else
        run_script_file "$RESOLVED_REL"
    fi
}

cmd_scripts() {
    local sub="${1:-list}"
    shift || true
    case "$sub" in
        list)
            cmd_scripts_list "$@"
            ;;
        run)
            if [ "$#" -lt 2 ]; then
                finish 1 "scripts run" "Usage: lpd scripts run <group> <script-path tokens...>"
                return 1
            fi
            local group="$1"
            shift
            cmd_scripts_run_internal "$group" "$@"
            ;;
        *)
            finish 1 "scripts" "Unknown scripts subcommand: $sub"
            ;;
    esac
}

cmd_group_shorthand() {
    local group="$1"
    shift
    cmd_scripts_run_internal "$group" "$@"
}

