{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.formatOnPaste": false,
  "editor.detectIndentation": false,
  "editor.inlineSuggest.enabled": false,
  "editor.codeActions.triggerOnFocusChange": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.eslint": "never",
    "source.organizeImports": "never"
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "git.autorefresh": false,
  "git.decorations.enabled": false,
  "git.untrackedChanges": "hidden",
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.codex/**": true,
    "**/v1/**": true,
    "**/tools/**": true,
    "**/tests/**": true,
    "**/tasks/**": true,
    "**/ai-tools/**": true,
    "**/api/**": true,
    "**/snippets/assets/**": true,
    "**/snippets/automations/**": true,
    "**/snippets/data/**": true,
    "**/snippets/snippetsWiki/**": true,
    "**/v2/cn/**": true,
    "**/v2/fr/**": true,
    "**/v2/es/**": true,
    "**/v2/x-archived/**": true
  },
  "search.exclude": {
    "**/.codex/**": true,
    "**/v1/**": true,
    "**/tools/**": true,
    "**/tests/**": true,
    "**/tasks/**": true,
    "**/ai-tools/**": true,
    "**/api/**": true,
    "**/snippets/assets/**": true,
    "**/snippets/automations/**": true,
    "**/snippets/data/**": true,
    "**/snippets/snippetsWiki/**": true,
    "**/v2/cn/**": true,
    "**/v2/fr/**": true,
    "**/v2/es/**": true,
    "**/v2/x-archived/**": true
  },
  "files.associations": {
    "*.mdx": "mdx",
    "docs.json": "json"
  },
  "prettier.configPath": ".prettierrc",
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": true,
  "eslint.enable": false,
  "eslint.validate": [],
  "eslint.probe": [],
  "cSpell.words": ["Arweave", "multistream"],
  "github.copilot.nextEditSuggestions.enabled": false,
  "github.copilot.enable": {
    "*": true,
    "mdx": false,
    "json": false,
    "jsonc": false
  },
  "gitlens.currentLine.enabled": false,
  "gitlens.statusBar.enabled": false,
  "gitlens.codeLens.enabled": false,
  "gitlens.hovers.currentLine.enabled": false,
  "gitlens.hovers.annotations.enabled": false,
  "gitlens.blame.highlight.enabled": false,
  "gitlens.blame.heatmap.enabled": false,
  "gitlens.launchpad.indicator.enabled": false,
  "gitlens.launchpad.indicator.polling.enabled": false,
  "gitlens.views.repositories.autoRefresh": false,
  "gitlens.views.repositories.autoReveal": false,
  "json.format.enable": true,
  "json.schemaDownload.enable": true,
  "emmet.includeLanguages": {
    "mdx": "html"
  },
  "[mdx]": {
    "editor.defaultFormatter": "livepeer.livepeer-authoring-tools",
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": false,
    "editor.wordBasedSuggestions": "off",
    "path-autocomplete.ignoredFilesPattern": "*.mdx"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": false,
    "path-autocomplete.ignoredFilesPattern": "**/docs.json",
    "editor.quickSuggestions": {
      "other": false,
      "comments": false,
      "strings": false
    },
    "editor.suggest.showSnippets": false,
    "editor.suggestOnTriggerCharacters": false,
    "editor.acceptSuggestionOnEnter": "off",
    "editor.wordBasedSuggestions": "off"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": false,
    "path-autocomplete.ignoredFilesPattern": "**/docs.json",
    "editor.quickSuggestions": {
      "other": false,
      "comments": false,
      "strings": false
    },
    "editor.suggest.showSnippets": false,
    "editor.suggestOnTriggerCharacters": false,
    "editor.acceptSuggestionOnEnter": "off",
    "editor.wordBasedSuggestions": "off"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  }
}
