{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "editor.formatOnPaste": false,
  "editor.detectIndentation": false,
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.eslint": "never",
    "source.organizeImports": "never"
  },
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/.codex/**": true,
    "**/v1/**": true,
    "**/tools/**": true,
    "**/tests/**": true,
    "**/tasks/**": true,
    "**/ai-tools/**": true,
    "**/api/**": true,
    "**/snippets/assets/**": true,
    "**/snippets/automations/**": true,
    "**/snippets/data/**": true,
    "**/snippets/snippetsWiki/**": true,
    "**/v2/cn/**": true,
    "**/v2/fr/**": true,
    "**/v2/es/**": true,
    "**/v2/x-archived/**": true
  },
  "search.exclude": {
    "**/.codex/**": true,
    "**/v1/**": true,
    "**/tools/**": true,
    "**/tests/**": true,
    "**/tasks/**": true,
    "**/ai-tools/**": true,
    "**/api/**": true,
    "**/snippets/assets/**": true,
    "**/snippets/automations/**": true,
    "**/snippets/data/**": true,
    "**/snippets/snippetsWiki/**": true,
    "**/v2/cn/**": true,
    "**/v2/fr/**": true,
    "**/v2/es/**": true,
    "**/v2/x-archived/**": true
  },
  "files.exclude": {
    "**/.codex": true,
    "**/v1": true,
    "**/tools": true,
    "**/tests": true,
    "**/tasks": true,
    "**/ai-tools": true,
    "**/api": true,
    "**/snippets/assets": true,
    "**/snippets/automations": true,
    "**/snippets/data": true,
    "**/snippets/snippetsWiki": true,
    "**/v2/cn": true,
    "**/v2/fr": true,
    "**/v2/es": true,
    "**/v2/x-archived": true
  },
  "files.associations": {
    "*.mdx": "mdx",
    "docs.json": "json"
  },
  "prettier.prettierPath": "./tools/node_modules/prettier",
  "prettier.configPath": ".prettierrc",
  "prettier.requireConfig": true,
  "prettier.useEditorConfig": true,
  "eslint.enable": false,
  "eslint.validate": [],
  "eslint.probe": [],
  "cSpell.words": ["Arweave", "multistream"],
  "json.format.enable": true,
  "json.schemaDownload.enable": true,
  "emmet.includeLanguages": {
    "mdx": "html"
  },
  "[mdx]": {
    "editor.defaultFormatter": "unifiedjs.vscode-mdx",
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": false,
    "editor.quickSuggestions": {
      "other": false,
      "comments": false,
      "strings": false
    },
    "editor.suggest.showSnippets": false,
    "editor.suggestOnTriggerCharacters": false,
    "editor.acceptSuggestionOnEnter": "off",
    "editor.wordBasedSuggestions": "off"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.inlineSuggest.enabled": false,
    "editor.quickSuggestions": {
      "other": false,
      "comments": false,
      "strings": false
    },
    "editor.suggest.showSnippets": false,
    "editor.suggestOnTriggerCharacters": false,
    "editor.acceptSuggestionOnEnter": "off",
    "editor.wordBasedSuggestions": "off"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  }
}
