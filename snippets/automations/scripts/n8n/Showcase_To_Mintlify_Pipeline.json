      "id": "save-to-sheet",
      "name": "Save to Google Sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [450, 300]
    },
    {
      "parameters": {
        "jsCode": "// Validate all fields\nconst data = $input.first().json;\nconst errors = [];\n\n// Required fields check\nconst required = ['title', 'subtitle', 'href', 'description', 'discordUsername'];\nfor (const field of required) {\n  if (!data[field] || data[field].trim() === '') {\n    errors.push(`Missing required field: ${field}`);\n  }\n}\n\n// URL validation helper\nfunction isValidUrl(string) {\n  try {\n    new URL(string);\n    return true;\n  } catch (_) {\n    return false;\n  }\n}\n\n// Validate main href\nif (data.href && !isValidUrl(data.href)) {\n  errors.push('Invalid project URL (href)');\n}\n\n// Validate mediaSrc\nif (data.mediaSrc && !isValidUrl(data.mediaSrc)) {\n  errors.push('Invalid media source URL');\n}\n\n// Validate logo\nif (data.logo && !isValidUrl(data.logo)) {\n  errors.push('Invalid logo URL');\n}\n\n// Validate links object\nif (data.links) {\n  try {\n    const links = typeof data.links === 'string' ? JSON.parse(data.links) : data.links;\n    for (const [key, value] of Object.entries(links)) {\n      if (value && !isValidUrl(value)) {\n        errors.push(`Invalid ${key} link`);\n      }\n    }\n  } catch (e) {\n    errors.push('Invalid links format');\n  }\n}\n\nreturn {\n  json: {\n    ...data,\n    isValid: errors.length === 0,\n    errors: errors,\n    errorMessage: errors.join(', ')\n  }\n};"
      },
