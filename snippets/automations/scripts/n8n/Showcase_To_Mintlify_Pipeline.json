      "id": "get-submission-data",
      "name": "Get Submission Data",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [1250, 700]
    },
    {
      "parameters": {
        "jsCode": "// Build the project object for GitHub\nconst data = $input.first().json;\n\n// Parse links if it's a string\nlet links = data.links;\nif (typeof links === 'string') {\n  try {\n    links = JSON.parse(links);\n  } catch (e) {\n    links = {};\n  }\n}\n\n// Parse tags if they're strings\nconst categoryTags = typeof data.categoryTags === 'string' \n  ? data.categoryTags.split(',').map(t => t.trim())\n  : data.categoryTags;\n\nconst productTags = typeof data.productTags === 'string'\n  ? data.productTags.split(',').map(t => t.trim())\n  : data.productTags;\n\nconst projectObject = {\n  title: data.title,\n  subtitle: data.subtitle,\n  href: data.href,\n  mediaSrc: data.mediaSrc,\n  logo: data.logo,\n  categoryTags: categoryTags,\n  productTags: productTags,\n  description: data.description,\n  cta: data.cta,\n  links: links\n};\n\n// Format as JSX array element with proper indentation\nconst formattedProject = JSON.stringify(projectObject, null, 2)\n  .split('\\n')\n  .map(line => '  ' + line)\n  .join('\\n');\n\nreturn {\n  json: {\n    ...data,\n    formattedProject: formattedProject,\n    projectObject: projectObject\n  }\n};"
      },
      "id": "format-for-github",
      "name": "Format for GitHub",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 700]
    },
    {
      "parameters": {
        "authentication": "oAuth2",
        "owner": "livepeer",
        "repository": "docs",
        "filePath": "path/to/your/projects.jsx",
        "operation": "get"
      },
      "id": "get-github-file",
      "name": "Get GitHub File",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [1650, 700]
    },
    {
      "parameters": {
        "jsCode": "// Get current file content and new project\nconst currentContent = $input.first().json.content;\nconst newProject = $('Format for GitHub').first().json.formattedProject;\n\n// Decode base64 content\nconst decodedContent = Buffer.from(currentContent, 'base64').toString('utf-8');\n\n// Find the projects array\n// Looking for pattern: const projects = [ ... ];\nconst arrayStart = decodedContent.indexOf('const projects = [');\nconst arrayEnd = decodedContent.lastIndexOf('];');\n\nif (arrayStart === -1 || arrayEnd === -1) {\n  throw new Error('Could not find projects array in file');\n}\n\n// Insert new project before the closing bracket\nconst beforeArray = decodedContent.substring(0, arrayEnd);\nconst afterArray = decodedContent.substring(arrayEnd);\n\n// Add comma if there are existing projects\nconst needsComma = beforeArray.trim().endsWith('}');\nconst updatedContent = beforeArray + \n  (needsComma ? ',' : '') + \n  '\\n' + newProject + '\\n' + \n  afterArray;\n\n// Encode back to base64\nconst encodedContent = Buffer.from(updatedContent).toString('base64');\n\nreturn {\n  json: {\n    content: encodedContent,\n    sha: $input.first().json.sha,\n    message: `Add project: ${$('Format for GitHub').first().json.title}`\n  }\n};"
      },
