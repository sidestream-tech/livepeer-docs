    {
      "parameters": {
        "jsCode": "// Parse Discord interaction\nconst body = $input.first().json.body;\nconst customId = body.data?.custom_id || '';\nconst interactionType = body.type;\n\n// Type 3 = Message Component (button click)\n// Type 5 = Modal Submit\n\nif (interactionType === 3) {\n  // Button click\n  const submissionId = customId.split('_')[1];\n  const action = customId.startsWith('approve') ? 'approve' : 'deny';\n  \n  return {\n    json: {\n      interactionType: 'button',\n      action: action,\n      submissionId: submissionId,\n      userId: body.member?.user?.id || body.user?.id,\n      interactionToken: body.token,\n      interactionId: body.id\n    }\n  };\n} else if (interactionType === 5) {\n  // Modal submit\n  const submissionId = body.data.custom_id.split('_')[1];\n  const reason = body.data.components[0].components[0].value;\n  \n  return {\n    json: {\n      interactionType: 'modal',\n      submissionId: submissionId,\n      denyReason: reason,\n      userId: body.member?.user?.id || body.user?.id,\n      interactionToken: body.token,\n      interactionId: body.id\n    }\n  };\n}\n\nreturn { json: { interactionType: 'unknown' } };"
      },
