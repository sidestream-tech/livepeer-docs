capture_governance_header_snapshot() {
    local snapshot_path="$1"
    shift

    node - "$snapshot_path" "$@" <<'NODE'
const fs = require('fs');

const snapshotPath = process.argv[2];
const files = process.argv.slice(3);
const tags = [
  '@script',
  '@category',
  '@purpose',
  '@scope',
  '@owner',
  '@needs',
  '@purpose-statement',
  '@pipeline',
  '@usage'
];

function readTag(header, tag) {
  const match = header.match(new RegExp(`\\${tag}[ \\t]+([^\\n\\r]+)`));
  return match ? match[1].trim() : '';
}

const snapshot = {};
for (const filePath of files) {
  let header = '';
  try {
    header = fs.readFileSync(filePath, 'utf8').split(/\r?\n/).slice(0, 220).join('\n');
  } catch (_error) {
    header = '';
  }

  snapshot[filePath] = {};
  for (const tag of tags) {
    snapshot[filePath][tag] = readTag(header, tag);
  }
}

fs.writeFileSync(snapshotPath, JSON.stringify(snapshot, null, 2));
NODE
}

print_governance_header_fixes() {
    local snapshot_path="$1"
    shift

    node - "$snapshot_path" "$@" <<'NODE'
const fs = require('fs');

const snapshotPath = process.argv[2];
const files = process.argv.slice(3);
const tags = [
  '@script',
  '@category',
  '@purpose',
  '@scope',
  '@owner',
  '@needs',
  '@purpose-statement',
  '@pipeline',
  '@usage'
];

function readTag(header, tag) {
  const match = header.match(new RegExp(`\\${tag}[ \\t]+([^\\n\\r]+)`));
  return match ? match[1].trim() : '';
}

const before = JSON.parse(fs.readFileSync(snapshotPath, 'utf8'));
const lines = [];

for (const filePath of files) {
  let header = '';
  try {
    header = fs.readFileSync(filePath, 'utf8').split(/\r?\n/).slice(0, 220).join('\n');
  } catch (_error) {
    header = '';
  }

  for (const tag of tags) {
    const previous = before?.[filePath]?.[tag] || '';
    const next = readTag(header, tag);
    if (!next || previous === next) continue;
    if (!previous) {
      lines.push(`  ✓ Fixed: added ${tag} ${next} to ${filePath}`);
    } else {
      lines.push(`  ✓ Fixed: corrected ${tag} to ${next} in ${filePath}`);
    }
  }
}

if (lines.length > 0) {
  process.stdout.write(`${lines.join('\n')}\n`);
}
NODE
}

