run_governance_auto_repair() {
    (
        local governed_scripts=()
        local tmp_dir=""
        local report_path=""
        local snapshot_path=""
        local preview_out=""
        local apply_out=""
        local script_docs_out=""
        local preview_fix_count=0
        local preview_needs_count=0
        local apply_fix_count=0
        local verify_fix_count=0
        local verify_needs_count=0
        local preview_rc=0
        local apply_rc=0
        local script_docs_rc=0
        local auto_repaired=0
        local governed_script=""
        local modified_file=""
        while IFS= read -r governed_script; do
            if [ -n "$governed_script" ]; then
                governed_scripts+=("$governed_script")
            fi
        done < <(get_staged_governed_scripts)
        if [ ${#governed_scripts[@]} -eq 0 ]; then
            exit 0
        fi

        if ! supports_governance_repair_flow; then
            print_governance_dependency_error
            exit 1
        fi

        tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/precommit-governance.XXXXXX") || {
            print_governance_command_error "Failed to create a temporary governance report directory." ""
            exit 1
        }
        trap 'rm -rf "$tmp_dir"' EXIT

        report_path="$tmp_dir/SCRIPT_INVENTORY_FULL.json"
        snapshot_path="$tmp_dir/governance-header-snapshot.json"

        preview_out=$(node tools/scripts/validators/governance/audit-script-inventory.js \
            --fix --dry-run --staged-only --quiet --json --output "$tmp_dir" 2>&1)
        preview_rc=$?
        if [ $preview_rc -ne 0 ] || [ ! -f "$report_path" ]; then
            print_governance_command_error "Governance preview failed before repair." "$preview_out"
            exit 1
        fi

        preview_fix_count=$(governance_report_fix_count "$report_path")
        preview_needs_count=$(governance_report_needs_human_count "$report_path")

        if [ "$preview_fix_count" -eq 0 ] && [ "$preview_needs_count" -gt 0 ]; then
            echo ""
            print_governance_manual_guidance "$report_path"
            echo ""
            echo "  Run 'cd tools && npm run repair:governance -- --dry-run' for more detail."
            echo "  To skip: SKIP_VERIFICATION=1 git commit -m 'message'"
            echo ""
            exit 1
        fi

        if [ "$preview_fix_count" -gt 0 ]; then
            local planned_files=()
            local dirty_targets=()
            local planned_file=""
            local dirty_target=""
            local modified_files=()

            while IFS= read -r planned_file; do
                if [ -n "$planned_file" ]; then
                    planned_files+=("$planned_file")
                fi
            done < <(governance_report_list_files "$report_path" planned_files)
            for planned_file in "${planned_files[@]}"; do
                if [ -z "$planned_file" ]; then
                    continue
                fi
                if [ -e "$planned_file" ] && ! git diff --quiet -- "$planned_file" 2>/dev/null; then
                    dirty_targets+=("$planned_file")
                fi
            done

            if [ ${#dirty_targets[@]} -gt 0 ]; then
                echo ""
                echo "✗ Governance auto-repair blocked by unstaged edits."
                echo ""
                for dirty_target in "${dirty_targets[@]}"; do
                    echo "  $dirty_target"
                done
                echo ""
                echo "  Stage or discard the unstaged edits in these files, then retry."
                echo "  Run 'cd tools && npm run repair:governance -- --dry-run' for more detail."
                echo "  To skip: SKIP_VERIFICATION=1 git commit -m 'message'"
                echo ""
                exit 1
            fi

            if ! capture_governance_header_snapshot "$snapshot_path" "${governed_scripts[@]}"; then
                print_governance_command_error "Failed to snapshot governed script headers before repair." ""
                exit 1
            fi

            echo ""
            echo "⚠  Governance issues detected. Attempting auto-repair..."
            echo ""

            apply_out=$(node tools/scripts/validators/governance/audit-script-inventory.js \
                --fix --staged-only --quiet --json --output "$tmp_dir" 2>&1)
            apply_rc=$?
            if [ $apply_rc -ne 0 ] || [ ! -f "$report_path" ]; then
                print_governance_command_error "Governance auto-repair failed." "$apply_out"
                exit 1
            fi

            while IFS= read -r modified_file; do
                if [ -n "$modified_file" ]; then
                    modified_files+=("$modified_file")
                fi
            done < <(governance_report_list_files "$report_path" files_modified)
            if [ ${#modified_files[@]} -gt 0 ]; then
                if ! git add -- "${modified_files[@]}" 2>/dev/null; then
                    print_governance_command_error "Failed to re-stage governance repair outputs." ""
                    exit 1
                fi
            fi

            print_governance_header_fixes "$snapshot_path" "${governed_scripts[@]}"
            apply_fix_count=$(governance_report_fix_count "$report_path")
            auto_repaired=1
        fi

        preview_out=$(node tools/scripts/validators/governance/audit-script-inventory.js \
            --fix --dry-run --staged-only --quiet --json --output "$tmp_dir" 2>&1)
        preview_rc=$?
        if [ $preview_rc -ne 0 ] || [ ! -f "$report_path" ]; then
            print_governance_command_error "Governance verification preview failed after repair." "$preview_out"
            exit 1
        fi

        verify_fix_count=$(governance_report_fix_count "$report_path")
        verify_needs_count=$(governance_report_needs_human_count "$report_path")
        script_docs_out=$(node tests/unit/script-docs.test.js --staged 2>&1)
        script_docs_rc=$?

        if [ "$verify_needs_count" -gt 0 ]; then
            echo ""
            print_governance_manual_guidance "$report_path"
            echo ""
            echo "  Run 'cd tools && npm run repair:governance -- --dry-run' for more detail."
            echo "  To skip: SKIP_VERIFICATION=1 git commit -m 'message'"
            echo ""
            exit 1
        fi

        if [ "$verify_fix_count" -gt 0 ]; then
            echo ""
            echo "✗ Governance auto-repair did not converge."
            echo ""
            echo "  Remaining automated fixes are still reported after repair."
            echo "  Run 'cd tools && npm run repair:governance -- --dry-run' for more detail."
            echo "  To skip: SKIP_VERIFICATION=1 git commit -m 'message'"
            echo ""
            exit 1
        fi

        if [ $script_docs_rc -ne 0 ]; then
            echo ""
            echo "✗ Script documentation enforcement still failed after governance repair."
            echo ""
            printf '%s\n' "$script_docs_out" | sed 's/^/  /'
            echo ""
            echo "  Run 'cd tools && npm run repair:governance -- --dry-run' for more detail."
            echo "  To skip: SKIP_VERIFICATION=1 git commit -m 'message'"
            echo ""
            exit 1
        fi

        if [ "$auto_repaired" = "1" ]; then
            echo ""
            echo "✓ Auto-repaired ${apply_fix_count} issue(s). Proceeding with commit."
            echo ""
        fi

        exit 0
    )
}

