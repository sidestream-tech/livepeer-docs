#!/bin/bash
# @script            pre-push
# @category          orchestrator
# @purpose           infrastructure:pipeline-orchestration
# @scope             .githooks, tools/scripts/validate-codex-task-contract.js, .codex/task-contract.yaml
# @owner             docs
# @needs             R-R29
# @purpose-statement Pre-push hook — blocks push if AI stash files present, codex locks stale, or task contract invalid
# @pipeline          P2 (push, hook entry point)
# @usage             bash .githooks/pre-push [flags]
set -u

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
ALLOW_CODEX_FORCE_PUSH="${ALLOW_CODEX_FORCE_PUSH:-0}"
ALLOW_MAIN_PUSH="${ALLOW_MAIN_PUSH:-0}"

# Read stdin first so we can inspect all pushed refs while still validating branch scope.
PUSH_LINES=$(cat)

is_codex_session() {
  if [[ "${CODEX_SHELL:-0}" == "1" ]]; then
    return 0
  fi

  if [[ -n "${CODEX_THREAD_ID:-}" ]]; then
    return 0
  fi

  if [[ "${CODEX_CI:-0}" == "1" ]]; then
    return 0
  fi

  if [[ -n "${CODEX_INTERNAL_ORIGINATOR_OVERRIDE:-}" ]]; then
    return 0
  fi

  return 1
}

TARGETS_DOCS_V2=0
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  if [[ -z "${local_ref:-}" ]]; then
    continue
  fi

  if [[ "${remote_ref:-}" == "refs/heads/docs-v2" ]]; then
    TARGETS_DOCS_V2=1
    break
  fi
done <<< "$PUSH_LINES"

if [[ "$TARGETS_DOCS_V2" -eq 1 ]] && is_codex_session; then
  if [[ "$ALLOW_MAIN_PUSH" != "1" ]]; then
    echo -e "${RED}❌ Push blocked: Codex sessions must not push directly to docs-v2.${NC}"
    echo -e "${YELLOW}Use codex/<issue-id>-<slug> branches and open a PR.${NC}"
    echo -e "${YELLOW}Do not stash/reset to switch. Keep work in place with:${NC}"
    echo "  git switch -c codex/<issue-id>-<slug>"
    echo -e "${YELLOW}Human override (explicit chat instruction required):${NC}"
    echo "  ALLOW_MAIN_PUSH=1 git push origin <branch>:docs-v2"
    exit 1
  fi

  echo -e "${YELLOW}⚠️ ALLOW_MAIN_PUSH=1 set; overriding docs-v2 push block for this push.${NC}"
fi

if [[ "$CURRENT_BRANCH" != codex/* ]]; then
  exit 0
fi

echo -e "${YELLOW}🔍 Running codex pre-push enforcement for ${CURRENT_BRANCH}${NC}"

if ! node tools/scripts/validate-codex-task-contract.js --branch "$CURRENT_BRANCH" --quiet; then
  echo -e "${RED}❌ Codex task contract validation failed. Push blocked.${NC}"
  exit 1
fi

if [ -f "tools/scripts/codex/validate-locks.js" ]; then
  if ! node tools/scripts/codex/validate-locks.js --branch "$CURRENT_BRANCH" --quiet; then
    echo -e "${RED}❌ Codex local lock validation failed. Push blocked.${NC}"
    exit 1
  fi
else
  echo -e "${RED}❌ Missing codex lock validator: tools/scripts/codex/validate-locks.js${NC}"
  exit 1
fi

if [ -x "tools/scripts/check-no-ai-stash.sh" ]; then
  if ! bash tools/scripts/check-no-ai-stash.sh --branch "$CURRENT_BRANCH" --quiet; then
    echo -e "${RED}❌ AI stash policy violation detected. Push blocked.${NC}"
    exit 1
  fi
fi

BLOCKED=0

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  if [[ -z "${local_ref:-}" ]]; then
    continue
  fi

  if [[ "${remote_ref:-}" != "refs/heads/${CURRENT_BRANCH}" ]]; then
    continue
  fi

  if [[ "${local_sha:-}" =~ ^0+$ ]]; then
    echo -e "${RED}❌ Deleting codex branches by push is blocked: ${remote_ref}${NC}"
    BLOCKED=1
    continue
  fi

  # New remote branch creation is always a fast-forward push.
  if [[ "${remote_sha:-}" =~ ^0+$ ]]; then
    continue
  fi

  if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" >/dev/null 2>&1; then
    echo -e "${RED}❌ Non-fast-forward push detected for ${remote_ref}${NC}"
    BLOCKED=1
  fi
done <<< "$PUSH_LINES"

if [[ "$BLOCKED" -eq 1 ]]; then
  if [[ "$ALLOW_CODEX_FORCE_PUSH" == "1" ]]; then
    echo -e "${YELLOW}⚠️ ALLOW_CODEX_FORCE_PUSH=1 set; overriding codex non-fast-forward block.${NC}"
    exit 0
  fi
  echo -e "${RED}Push blocked. Use a fast-forward push on codex/* branches.${NC}"
  echo -e "${YELLOW}If an override is explicitly approved, set ALLOW_CODEX_FORCE_PUSH=1 for that push.${NC}"
  exit 1
fi

echo -e "${GREEN}✓ Codex pre-push checks passed${NC}"
exit 0
