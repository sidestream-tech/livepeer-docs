# Notion API credentials
# Get your API key from: https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your_api_key_here

# Get your database ID from the database URL
# Example URL: https://www.notion.so/2f0660222d088091a81fc6a57ee30c83?v=...
# Database ID: 2f0660222d088091a81fc6a57ee30c83
NOTION_DATABASE_ID=your_database_id_here

