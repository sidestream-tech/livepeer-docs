{
  "name": "livepeer-docs-tools",
  "version": "1.0.0",
  "description": "Development tooling for Livepeer documentation",
  "devDependencies": {
    "@cspell/dict-en-gb": "^5.0.0",
    "cspell": "^8.0.0",
    "js-yaml": "^4.1.0",
    "prettier": "^3.7.4",
    "puppeteer": "^24.37.3",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "minimatch": "^10.0.3",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "scripts": {
    "format-mdx": "node convert-jsx-comments-to-markdown.js '**/*.mdx' && prettier --write '**/*.mdx'",
    "audit:scripts": "node scripts/validators/governance/audit-script-inventory.js --md --json",
    "audit:scripts:verbose": "node scripts/validators/governance/audit-script-inventory.js --md --json --verbose",
    "audit:repo": "node scripts/repo-audit-orchestrator.js --mode static --scope full",
    "audit:repo:changed": "node scripts/repo-audit-orchestrator.js --mode static --scope changed",
    "audit:repo:full": "node scripts/repo-audit-orchestrator.js --mode full --scope full",
    "audit:repo:quarantine": "node scripts/repo-audit-orchestrator.js --mode static --scope full --quarantine",
    "audit:repo:pack-all": "node scripts/repo-audit-orchestrator.js --mode static --scope full --agent-pack all",
    "audit:component-layout": "node scripts/component-layout-governance.js --scope full",
    "audit:docs-quality": "node scripts/docs-quality-and-freshness-audit.js --scope full",
    "audit:language-en-gb": "node scripts/style-and-language-homogenizer-en-gb.js --scope full",
    "report:component-governance-remediation": "node scripts/generate-component-governance-remediation-reports.js",
    "registry:components": "node scripts/generate-component-registry.js",
    "cleanup:classify": "node scripts/cleanup-quarantine-manager.js",
    "cleanup:quarantine": "node scripts/cleanup-quarantine-manager.js --apply",
    "repair:mdx-safe-markdown": "node scripts/remediators/content/repair-mdx-safe-markdown.js --write",
    "repair:mdx-safe-markdown:dry-run": "node scripts/remediators/content/repair-mdx-safe-markdown.js --dry-run",
    "pack:agents": "node scripts/cross-agent-packager.js --agent-pack all",
    "skills:sync:codex": "node scripts/sync-codex-skills.js",
    "skills:sync:codex:check": "node scripts/sync-codex-skills.js --check",
    "codex:pr": "node scripts/create-codex-pr.js --create",
    "docs-guide:indexes": "node scripts/generate-docs-guide-indexes.js --write",
    "fetch-docs": "bash scripts/snippets/fetch-external-docs.sh",
    "generate-seo": "node scripts/snippets/generate-seo.js",
    "generate-seo:dry-run": "node scripts/snippets/generate-seo.js --dry-run",
    "prebuild": "bash scripts/snippets/fetch-external-docs.sh",
    "test:v2-pages": "node scripts/test-v2-pages.js",
    "test": "node ../tests/run-all.js",
    "test:style": "node ../tests/unit/style-guide.test.js",
    "test:mdx": "node ../tests/unit/mdx.test.js",
    "test:mdx:safe": "node scripts/validators/content/check-mdx-safe-markdown.js",
    "test:spell": "node ../tests/unit/spelling.test.js",
    "test:links": "node ../tests/unit/links-imports.test.js",
    "test:browser": "node ../tests/integration/browser.test.js",
    "test:browser:all": "node ../tests/integration/browser.test.js",
    "test:quality": "node ../tests/unit/quality.test.js",
    "test:all-pages": "node scripts/test-v2-pages.js",
    "i18n:translate": "node scripts/i18n/translate-docs.js",
    "i18n:docs-json": "node scripts/i18n/generate-localized-docs-json.js",
    "i18n:validate": "node scripts/i18n/validate-generated.js",
    "test:i18n": "node --test scripts/i18n/test/*.test.js"
  }
}
