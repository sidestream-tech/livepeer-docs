{
  "version": "1.0.0",
  "locale": "en-GB",
  "phase": "phase-1-en-only",
  "include_globs": ["v2/**/*.mdx"],
  "exclude_globs": [
    "v2/es/**",
    "v2/fr/**",
    "v2/cn/**",
    "v2/x-*/**",
    "v2/internal/**"
  ],
  "forbidden_terms": [
    "color",
    "colors",
    "optimize",
    "optimization",
    "organize",
    "organization",
    "recognize",
    "recognized"
  ],
  "forbidden_patterns": [
    "/v2/pages/",
    "style={{",
    "ThemeData"
  ]
}
