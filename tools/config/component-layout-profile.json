{
  "version": "1.0.0",
  "page_types": [
    {
      "page_type": "landing",
      "match": {
        "path_contains": ["/index.mdx", "portal", "overview"]
      },
      "required_sections": ["Overview"],
      "allowed_components": ["Card", "CardGroup", "Tabs", "Accordion", "Steps", "Note", "Info", "Tip", "Warning"],
      "forbidden_patterns": ["TODO", "TBD"]
    },
    {
      "page_type": "how_to",
      "match": {
        "path_contains": ["how-to", "quickstart", "run-a-", "setup", "install"]
      },
      "required_sections": ["Prerequisites", "Steps"],
      "allowed_components": ["Steps", "Step", "CodeGroup", "RequestExample", "ResponseExample", "Warning", "Check", "Tip", "Note"],
      "forbidden_patterns": ["Coming Soon", "PreviewCallout"]
    },
    {
      "page_type": "reference",
      "match": {
        "path_contains": ["reference", "api", "cli-flags", "configuration-flags"]
      },
      "required_sections": ["Reference"],
      "allowed_components": ["ParamField", "ResponseField", "CodeGroup", "Tabs", "Table", "Warning", "Note"],
      "forbidden_patterns": ["TODO", "TBD", "Coming Soon"]
    },
    {
      "page_type": "tutorial",
      "match": {
        "path_contains": ["tutorial", "guide"]
      },
      "required_sections": ["Prerequisites", "Steps", "Next Steps"],
      "allowed_components": ["Steps", "Step", "CodeGroup", "Tip", "Warning", "Check", "Note"],
      "forbidden_patterns": ["Coming Soon"]
    }
  ]
}
