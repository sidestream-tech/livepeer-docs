{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.livepeer.org/schemas/skill-catalog.schema.json",
  "title": "Repo Audit Skill Catalog",
  "type": "object",
  "required": ["version", "skills"],
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/skill"
      }
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "required": ["name", "run", "modes"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "run": {
          "type": "string",
          "minLength": 1
        },
        "modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["static", "runtime", "full"]
          }
        }
      },
      "additionalProperties": false
    },
    "skill": {
      "type": "object",
      "required": [
        "id",
        "goal",
        "inputs",
        "commands",
        "outputs",
        "severity_model",
        "autofix_mode"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/command"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "severity_model": {
          "type": "string",
          "enum": ["critical-high-medium-low", "scorecard-0-100", "info-only"]
        },
        "autofix_mode": {
          "type": "string",
          "enum": ["none", "advisory", "safe", "requires-approval"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
