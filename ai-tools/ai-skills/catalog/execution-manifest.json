{
  "version": "1.0.0",
  "pipeline": [
    {
      "id": "script-footprint-and-usage-audit",
      "run_order": 1,
      "modes": ["static", "full"],
      "default_enabled": true
    },
    {
      "id": "docs-coverage-and-route-integrity-audit",
      "run_order": 2,
      "modes": ["static", "full"],
      "default_enabled": true
    },
    {
      "id": "docs-quality-and-freshness-audit",
      "run_order": 3,
      "modes": ["static", "full"],
      "default_enabled": true
    },
    {
      "id": "style-and-language-homogenizer-en-gb",
      "run_order": 4,
      "modes": ["static", "full"],
      "default_enabled": true
    },
    {
      "id": "component-layout-governance",
      "run_order": 5,
      "modes": ["static", "full"],
      "default_enabled": true
    },
    {
      "id": "cleanup-quarantine-manager",
      "run_order": 6,
      "modes": ["static", "full"],
      "default_enabled": true,
      "apply_only_when_quarantine_flag": true
    },
    {
      "id": "cross-agent-packager",
      "run_order": 7,
      "modes": ["static", "runtime", "full"],
      "default_enabled": true,
      "apply_only_when_agent_pack_requested": true
    }
  ]
}
