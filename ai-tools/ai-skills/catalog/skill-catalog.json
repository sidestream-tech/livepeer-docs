{
  "$schema": "./skill-catalog.schema.json",
  "version": "1.0.0",
  "skills": [
    {
      "id": "repo-audit-orchestrator",
      "goal": "Run a full docs infrastructure audit pipeline and produce a unified scorecard.",
      "inputs": ["repo state", "audit mode", "scope", "pipeline manifest", "skill catalog"],
      "commands": [
        {
          "name": "orchestrate",
          "run": "node tools/scripts/repo-audit-orchestrator.js --mode static --scope full",
          "modes": ["static", "runtime", "full"]
        }
      ],
      "outputs": [
        "tasks/reports/repo-ops/repo-audit-summary.md",
        "tasks/reports/repo-ops/repo-audit-summary.json"
      ],
      "severity_model": "scorecard-0-100",
      "autofix_mode": "advisory"
    },
    {
      "id": "rubric-static-review",
      "goal": "Provide static rubric-based scoring and risk prioritization.",
      "inputs": ["repository files", "architecture docs", "quality checks"],
      "commands": [
        {
          "name": "review",
          "run": "read ai-tools/ai-skills/rubric-static-review/SKILL.md",
          "modes": ["static", "full"]
        }
      ],
      "outputs": ["scorecard", "top actions"],
      "severity_model": "scorecard-0-100",
      "autofix_mode": "none"
    },
    {
      "id": "script-footprint-and-usage-audit",
      "goal": "Detect script sprawl, duplicates, placeholders, and backup artifacts.",
      "inputs": ["tools/scripts", "tests", "tasks/reports/repo-ops/SCRIPT_AUDIT.json"],
      "commands": [
        {
          "name": "audit",
          "run": "node tools/scripts/script-footprint-and-usage-audit.js --scope full",
          "modes": ["static", "full"]
        }
      ],
      "outputs": [
        "tasks/reports/repo-ops/script-footprint-and-usage-audit.md",
        "tasks/reports/repo-ops/script-footprint-and-usage-audit.json"
      ],
      "severity_model": "critical-high-medium-low",
      "autofix_mode": "advisory"
    },
    {
      "id": "docs-coverage-and-route-integrity-audit",
      "goal": "Identify route mismatches, legacy path drift, and orphaned docs candidates.",
      "inputs": ["docs.json", "v2/**", "navigation/link reports"],
      "commands": [
        {
          "name": "audit",
          "run": "node tools/scripts/docs-coverage-and-route-integrity-audit.js --scope full",
          "modes": ["static", "full"]
        }
      ],
      "outputs": [
        "tasks/reports/repo-ops/docs-coverage-and-route-integrity-audit.md",
        "tasks/reports/repo-ops/docs-coverage-and-route-integrity-audit.json"
      ],
      "severity_model": "critical-high-medium-low",
      "autofix_mode": "advisory"
    },
    {
      "id": "docs-quality-and-freshness-audit",
      "goal": "Surface TODO/TBD/Coming Soon markers, thin content, and freshness risk.",
      "inputs": ["v2 English docs", "usefulness reports"],
      "commands": [
        {
          "name": "audit",
          "run": "node tools/scripts/docs-quality-and-freshness-audit.js --scope full",
          "modes": ["static", "full"]
        }
      ],
      "outputs": [
        "tasks/reports/repo-ops/docs-quality-and-freshness-audit.md",
        "tasks/reports/repo-ops/docs-quality-and-freshness-audit.json"
      ],
      "severity_model": "critical-high-medium-low",
      "autofix_mode": "advisory"
    },
    {
      "id": "style-and-language-homogenizer-en-gb",
      "goal": "Enforce UK English and style consistency on English v2 docs in phase 1.",
      "inputs": ["v2 English docs", "tools/config/cspell.json", "style profile"],
      "commands": [
        {
          "name": "audit",
          "run": "node tools/scripts/style-and-language-homogenizer-en-gb.js --scope full",
          "modes": ["static", "full"]
        }
      ],
      "outputs": [
        "tasks/reports/repo-ops/style-and-language-homogenizer-en-gb.md",
        "tasks/reports/repo-ops/style-and-language-homogenizer-en-gb.json"
      ],
      "severity_model": "critical-high-medium-low",
      "autofix_mode": "advisory"
    },
    {
      "id": "component-layout-governance",
      "goal": "Validate page composition against component layout contracts by page type.",
      "inputs": ["v2 English docs", "component layout profile"],
      "commands": [
        {
          "name": "audit",
          "run": "node tools/scripts/component-layout-governance.js --scope full",
          "modes": ["static", "full"]
        }
      ],
      "outputs": [
        "tasks/reports/repo-ops/component-layout-governance.md",
        "tasks/reports/repo-ops/component-layout-governance.json"
      ],
      "severity_model": "critical-high-medium-low",
      "autofix_mode": "advisory"
    },
    {
      "id": "cleanup-quarantine-manager",
      "goal": "Classify cleanup candidates and apply conservative quarantine only when requested.",
      "inputs": ["repository files", "report retention policy", "cleanup manifest"],
      "commands": [
        {
          "name": "classify",
          "run": "node tools/scripts/cleanup-quarantine-manager.js",
          "modes": ["static", "full"]
        },
        {
          "name": "apply",
          "run": "node tools/scripts/cleanup-quarantine-manager.js --apply",
          "modes": ["full"]
        }
      ],
      "outputs": [
        "tasks/reports/repo-ops/cleanup-quarantine-manifest.json",
        "tasks/reports/repo-ops/cleanup-quarantine-manifest.md"
      ],
      "severity_model": "critical-high-medium-low",
      "autofix_mode": "requires-approval"
    },
    {
      "id": "cross-agent-packager",
      "goal": "Generate consistent skill packs for Codex, Cursor, Claude Code, and Windsurf.",
      "inputs": ["skill catalog", "execution manifest"],
      "commands": [
        {
          "name": "package",
          "run": "node tools/scripts/cross-agent-packager.js --agent-pack all",
          "modes": ["static", "runtime", "full"]
        }
      ],
      "outputs": [
        "ai-tools/agent-packs/codex/skills-manifest.json",
        "ai-tools/agent-packs/cursor/rules.md",
        "ai-tools/agent-packs/claude/CLAUDE.md",
        "ai-tools/agent-packs/windsurf/rules.md"
      ],
      "severity_model": "info-only",
      "autofix_mode": "safe"
    }
  ]
}
